DB_URL=postgresql+psycopg2://feedrh:feedrh@localhost:5432/feedrh

# Em deploys como Coolify, prefira DATABASE_URL quando a plataforma fornecer
# uma connection string valida para a rede interna da aplicacao.
# DATABASE_URL=postgresql+psycopg2://usuario:senha@postgres:5432/feedrh
#
# Alternativamente, configure as variaveis separadas abaixo. O backend monta
# a URL automaticamente quando DATABASE_URL nao estiver definida.
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=feedrh
# POSTGRES_USER=feedrh
# POSTGRES_PASSWORD=feedrh
#
# Retry inicial para aguardar o banco/DNS do container ficar disponivel.
DB_CONNECT_RETRIES=10
DB_CONNECT_RETRY_SECONDS=2

MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Sistema de Recrutamento
MAIL_USE_TLS=true
MAIL_USE_SSL=false

# URL usada nos e-mails de avanço de vaga, acesso inicial de gestores, reset de senha
# e como origem permitida no CORS do backend. O backend tambem aceita a variante
# http/https da origem configurada.
# No backend separado do Coolify, use:
# APP_URL=http://feedrh.ora.dev.br
APP_URL=http://localhost:4200

# Origem(s) adicional(is) permitida(s) no CORS, separadas por virgula.
# FRONTEND_URL=http://feedrh.ora.dev.br
# CORS_ORIGINS=http://localhost:4200,http://feedrh.ora.dev.br

# URL usada no build do frontend. Em producao, mantenha /api; o Nginx do
# frontend encaminha /api para BACKEND_URL.
API_URL=/api

# Variaveis do container frontend/Nginx. Configure no app frontend do Coolify.
# BACKEND_URL deve incluir o protocolo e nao deve terminar com barra.
BACKEND_URL=http://api.feedrh.ora.dev.br
BACKEND_HOST=api.feedrh.ora.dev.br

# Nivel dos logs do backend.
LOG_LEVEL=INFO
